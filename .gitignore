# ══════════════════════════════════════════════════════════════
#  DANK Cannabis Club — .gitignore
#  Prevents secrets and OS/editor clutter from going to GitHub
# ══════════════════════════════════════════════════════════════

# ── CREDENTIALS (never commit these) ─────────────────────────
# Your actual Supabase URL + Anon Key live here:
assets/js/config.js

# EmailJS credentials:
assets/js/emailjs-config.js

# .env is documentation-only for this static site,
# but gitignore it anyway as a safety net:
.env
.env.local
.env.production

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Editors ───────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Node (if you ever add a build step) ──────────────────────
node_modules/
dist/
.cache/
